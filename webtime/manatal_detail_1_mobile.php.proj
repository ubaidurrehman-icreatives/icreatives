	Function TotalHrs($i) {
	
	$TotalHrs = $row["OUTHR" . $i] - $row["INHR" . $i] - $row["BREAK" . $i];
	
	return $TotalHrs;
	} 
	
	Function DecToTime($Hrs) {
	$Hrs = str_pad(floor($Hrs),2,"0", STR_PAD_LEFT) . ":" . str_pad(round(($Hrs - floor($Hrs))*60,0),2,"0", STR_PAD_LEFT) ;

	return $Hrs;
}
