      document.location.assign("/portal/manatal_rate_candidates.php/?cand=<?php echo $_REQUEST['cand'] - 1; ?>&o=<?php echo $order ?>");
  }, false);
});

// process a change of interview time radio button
Array.prototype.forEach.call(document.querySelector('input[type="radio"][name="interview_option"]'), function(e) {
  e.addEventListener('change', function() {
    // set required to true
    document.getElementById('interviewDate').required = this.value == "1";
  }, false);
});

// set input-mask required to true/false on change of medium_include checkbox
Array.prototype.forEach.call(document.querySelectorAll('.medium_include'), function(include) {
  if(include.checked) {
    document.getElementById('input_mask-'+include.value).required = true;
    document.getElementById('input_mask-'+include.value).dataset.required = true;
  } else {
    document.getElementById('input_mask-'+include.value).required = false;
    document.getElementById('input_mask-'+include.value).dataset.required = false;
  }
  include.addEventListener('change', function() {
    if(this.checked) {
      document.getElementById('input_mask-'+include.value).required = true;
      document.getElementById('input_mask-'+include.value).dataset.required = true;
    } else {
      document.getElementById('input_mask-'+include.value).required = false;
      document.getElementById('input_mask-'+include.value).dataset.required = false;
    }
  });
});

