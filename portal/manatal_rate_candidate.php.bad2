    $statusCode = $e->getResponse()->getStatusCode();

    $body = (string) $e->getResponse()->getBody();
    $json = json_decode($body, true);

    // Default wait time
    $wait = 60;

    if (isset($json['detail']) && preg_match('/available in (\d+) seconds/', $json['detail'], $matches)) {
        $wait = $matches[1];
    }

    echo "<p>The server is busy. Please wait {$wait} seconds. The page will reload automatically. (id)</p>";
    echo "<script>setTimeout(() => { location.reload(); }, " . ($wait * 1000) . ");</script>";

    exit();
}


