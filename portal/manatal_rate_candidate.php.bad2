var comments = document.getElementById('decline_comments');
var interview_btn1 = document.getElementById('interview1');
var interview_btn2 = document.getElementById('interview2');
var decline = document.getElementById('decline');

if(decline.checked) {
  interview_btn1.disabled = true;
  interview_btn2.disabled = true;
} else {
  interview_btn1.disabled = false;
  interview_btn2.disabled = false;
}

decline.addEventListener('change', function() {
  if(this.checked) {
    comments.required = true;
    interview_btn1.disabled = true;
    interview_btn2.disabled = true;
  } else {
    comments.required = false;
    interview_btn1.disabled = false;
    interview_btn2.disabled = false;
  }
});

