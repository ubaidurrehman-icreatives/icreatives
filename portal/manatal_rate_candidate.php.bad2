function userInfo($data, $field, $targetDisplayName) {

    foreach ($data['results'] as $entry) {
        if (isset($entry[$field]) && $entry[$field] == $targetDisplayName) {
            // Found the entry with the target display_name
            // Access other information if needed
            $id = $entry['id'];
            $email = $entry['email'];
            // ... other fields

            return $entry; // Return the entry
        }
    }

    return null; // Return null if not found
}


