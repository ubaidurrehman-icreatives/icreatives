  }
});

// prevent submit on enter

// add h hours to date
Date.prototype.addHours = function(h) {
  this.setTime(this.getTime() + (h*60*60*1000));
  return this;
}

var now = new Date();
let interviewDate = document.getElementById('interviewDate');
flatpickr("#interviewDate", {
  enableTime: true,
  static: true,
  dateFormat: "F, d Y H:i",
  defaultDate: interviewDate.value == "" ? now.addHours(1) : interviewDate.value, // 1 hour from now
  minuteIncrement: 1,
  minDate: "today"
});

flatpickr("#additionalDate1", {
  enableTime: true,
  static: true,
  dateFormat: "F, d Y H:i",
  minuteIncrement: 1,
  minDate: "today"
});

flatpickr("#additionalDate2", {
  enableTime: true,
  static: true,
  dateFormat: "F, d Y H:i",
  minuteIncrement: 1,
  minDate: "today"
});

flatpickr("#additionalDate3", {
  enableTime: true,
  static: true,
  dateFormat: "F, d Y H:i",
  minuteIncrement: 1,
  minDate: "today"
});

// determine if any inputs have changed and should be saved
function shouldSave() {
  var numChanged = 0;
  Array.prototype.forEach.call(document.querySelectorAll('input[data-changed]'), function(input) {
    if(input.dataset.changed === "1") {
      numChanged++;
    }
  });
  Array.prototype.forEach.call(document.querySelectorAll('textarea[data-changed]'), function(input) {
    if(input.dataset.changed === "1") {
      numChanged++;
    }
  });
  if(numChanged > 0) {
    return !confirm("There is at least one field that has not been saved. Are you sure you want to leave this page without saving?");
  }
  return 0;
}

// add data-changed to input for validation. used onchange
function setChanged(input) {
  if(input.value !== input.dataset.original) {
    input.dataset.changed = 1;
  } else {
    input.dataset.changed = 0;
  }
}

var preventSubmit = function(e) {
  if(!e.target.matches('textarea') && !e.target.matches('submit')) {
    var keyCode = e.keyCode || e.which;
    if (keyCode === 13) {
      e.preventDefault();
      return false;
    }
  }
}

window.addEventListener('keyup', preventSubmit, false);
window.addEventListener('keypress', preventSubmit, false);

// Setup stars
var checkedStar = document.getElementById('rating').value;
Array.prototype.forEach.call(document.getElementsByClassName('star'), function(e) {
  // set appropriate stars to checked
  if(e.checked) {
    checkedStar = e.value;
  }
});
if(checkedStar != 0) document.getElementById('star'+checkedStar).checked = true;

// render pdf
<?php if($is_valid) { ?>
var canvas = document.getElementById('resume');
var pdfjs = window['pdfjs-dist/build/pdf'];
pdfjs.GlobalWorkerOptions.workerSrc =
  "https://cdn.jsdelivr.net/npm/pdfjs-dist@2.7.570/build/pdf.worker.min.js";
// '//mozilla.github.io/pdf.js/build/pdf.worker.js';
var pdf = "<?php echo $resume ?>";
var loadingTask = pdfjs.getDocument(pdf);
loadingTask.promise.then(function(pdf) {
  console.log('PDF loaded');

  // Fetch the first page
  var pageNumber = 1;
  pdf.getPage(pageNumber).then(function(page) {
    console.log('Page loaded');

    var renderScale = 3;  // resolution goes up as scale goes up
    var viewport = page.getViewport({scale:renderScale});
    var context = canvas.getContext('2d');
    canvas.width = viewport.width;
    canvas.height = viewport.height;
    canvas.style.width = '100%';
    canvas.style.height = viewport.height*(canvas.style.width/canvas.width);

    // Render PDF page into canvas context
    var renderContext = {
      canvasContext: context,
      viewport: viewport
    };
    var renderTask = page.render(renderContext);
    renderTask.promise.then(function () {
      console.log('Page rendered');
    });
  });
}, function (e) {
  // PDF loading error
  console.error(e);
});
<?php } ?>

var modal = document.getElementById('myModal');

/*
  input - bool (require)
  set each mask's required property to input
*/
function set_require(require) {
  document.getElementById("asap").required = require;
  document.getElementById("set_date").required = require;
  Array.prototype.forEach.call(document.querySelectorAll('.medium_mask'), function(mask) {
    mask.required = mask.dataset.required === "true" && require;
  });
}

// When user clicks the button, open the modal display
Array.prototype.forEach.call(document.getElementsByClassName('set_interview_btn'), function(e) {
  e.addEventListener('click', function() {
    set_require(true);
    modal.style.display = "block";
  }, false)
});

// When the user clicks on (x), close the modal
document.getElementById('close_interview_dialogue').addEventListener('click', function() {
  modal.style.display="none";
  set_require(false);
}, false);

// share modal control
var share = document.getElementById('share_dialogue');

Array.prototype.forEach.call(document.getElementsByClassName('share'), function(e) {
  e.addEventListener('click', function() {
    share.style.display = "block";
  }, false);
});

document.getElementById('close_share_dialogue').addEventListener('click', function() {
  share.style.display="none";
}, false);

document.getElementById('share').addEventListener('submit', function(e) {
  let btn = document.getElementById('share_submit');
  document.getElementById('share_message').innerHTML = "";
  btn.disabled = true;
  btn.innerHTML = "Please wait...";
  var share_email = document.getElementById('share_email');
  var address = share_email.value;
  share_email.value = '';

  // create new share ticket and retrieve seletor (s) and validator (t)
  var xhttp = new XMLHttpRequest();
  xhttp.open('POST', '/portal/manatal_process_share.php', true);
  xhttp.setRequestHeader("Content-Type", "application/x-www-form-urlencoded");
  xhttp.onreadystatechange = function() {
    if(this.readyState == 4 && this.status == 200) {
      try {
        btn.innerHTML = "Share";
        btn.disabled = false;

        var data = JSON.parse(this.response);
        if("e" in data) {
          alert("Sorry, there was a problem sharing this candidate.");
        } else {
          /*
            selector = data.s
            validator = data.t
          */

          document.getElementById('share_message').innerHTML = "Message successfully sent. You may need to alert the recipient to check their spam folder.";
          // window.location.href = 'mailto:'+address+'?body=Please%20check%20out%20this%20candidate%20icreatives%20sent%20to%20us%20for%20the%20position%20<?php echo $position ?>.%0A%0AYou%20can%20find%20their%20information%20here%3A%0Ahttps%3A%2F%2Fwww.icreatives.com%2Fpreview-candidate%2F%3Fd%3D'+data.s+'%26v%3D'+data.t+'&subject=This%20candidate%20is%20wonderful!!';
        }
      } catch(err) {
        alert("There was a problem sharing this candidate.");
        console.log(this.response);
      }
    }
  }
  xhttp.send("email="+address+"&o=<?php echo $order ?>&c=<?php echo $candidateID ?>");
  e.preventDefault();
});

/*
  process click "away" from a modal view
  more accurately, this is a click on the modal view's background
*/
window.onclick = function(e) {
  if (e.target == modal) {
    // unrequire modal's mask inputs
    set_require(false);
    modal.style.display = "none";
  } else if (e.target == share) {
    share.style.display = "none";
  }
}

/*
  format a string
  result -
    {
      formatted - formatted string
      value - raw value
    }

  0 - any digit
  * - any char
*/
String.prototype.format = function(format) {
  var original = this;
  var final = {
    formatted: "",
    value: ""
  };
  var j = 0;
  for(let i = 0; i < format.length && j < original.length; i++) {
    if(format[i] === '0') {
      if(/^[0-9]$/.test(original[j])) {
        final.formatted += original[j];
        final.value += original[j];
      }
      j++;
    } else if(format[i] === '*') {
      final.formatted += original[j];
      final.value += original[j];
      j++;
    } else {
      final.formatted += format[i];
    }
  }
  return final;
}

/*
  input - formatted string (this), format
  output - raw value
*/
String.prototype.normalize = function(format) {
  var original = this;
  var final = "";

  var skipped = "";

  /*
    skipped not empty and original[j+] equals skipped
      go back in format string by the number of characters that were skipped
    format[i] = '0'
      if original[j] is a digit, add to final
      else continue to next format character
    format[i] = '*'
      add original[j] to final
    else
      "automatcally added" characters not yet in string
      skip format[i] and add to skipped
  */
  for(i = 0, j = 0; i < format.length && j < original.length; i++) {
    if(skipped != "" && original.substr(j, skipped.length) === skipped) {
      i -= skipped.length;
      skipped = '';
    } else if(format[i] === '0') {
      if(/^[0-9]$/.test(original[j])) {
        final += original[j];
      } else {
        continue;
      }
    } else if(format[i] === '*') {
      final += original[j];
    } else if(original[j] !== format[i]) {
      skipped += format[i];
      continue;
    }
    j++;
  }

  return final;
}

// format each mask
Array.prototype.forEach.call(document.getElementsByClassName('medium_info'), function(e) {
  var mask = document.getElementById('input_mask-'+e.dataset.type);
  if(mask.dataset.pattern === "") {
    mask.value = e.value;
    return;
  }
  var result = e.value.format(mask.dataset.pattern);
  mask.value = result.formatted;
});

// process input to mask
Array.prototype.forEach.call(document.getElementsByClassName('medium_mask'), function(mask) {
  mask.addEventListener('input', function() {
    var type = mask.dataset.type;
    mask.required = true;
    document.getElementById('medium_'+type).checked = true;
    try {
      if(mask.dataset.pattern === "") {
        document.getElementById('input-'+type).value = mask.value;
        return;
      }
      var cursorLoc = mask.selectionStart; // original cursor location
      var originalMask = mask.value; // original value
      var originalVal = document.getElementById('input-'+type).value; // original raw value
      var val = mask.value.normalize(mask.dataset.pattern); // raw value
      var result = val.format(mask.dataset.pattern); // result of format raw value
      console.log([val, result]);
      document.getElementById('input-'+type).value = result.value; // set input to raw value
      mask.value = result.formatted; // set mask to formatted value

      // handle cursor Location
      // TODO: properly handle input from center
      if(result.value.length > originalVal.length) {
        //this.setSelectionRange(cursorLoc + (result.value.length - originalVal.length), cursorLoc + (result.value.length - originalVal.length));
      } else {
        this.setSelectionRange(cursorLoc, cursorLoc);
      }
    } catch(err) {
      console.log(err);
    }

    if(mask.value.length !== mask.dataset.pattern.length && mask.dataset.pattern !== "" && mask.value.length !== 0) {
      mask.setCustomValidity("Please completely fill this field.");
    } else {
      mask.setCustomValidity("");
    }
  }, false);
});

